{
  "name": "cristales-de-la-cueva",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mini plataformero pixel-art para aprender y crecer de a poco hacia un metroidvania.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "check": "esbuild scripts/check.ts --bundle --platform=node --format=esm --outfile=scripts/.check.mjs --log-level=warning && node scripts/.check.mjs",
    "viz": "esbuild scripts/visualize.ts --bundle --platform=node --format=esm --outfile=scripts/.visualize.mjs --log-level=warning && node scripts/.visualize.mjs",
    "shots": "node scripts/shots.mjs",
    "rooms": "node scripts/rooms.mjs",
    "reach": "esbuild scripts/reach-cli.ts --bundle --platform=node --format=esm --outfile=scripts/.reach.mjs --log-level=warning && node scripts/.reach.mjs"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
